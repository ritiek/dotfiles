# Wakeupgen is the root interrupt-parent in sun60iw2p1.dtsi — ALL pinctrl/GPIO interrupts
# route through it. Without this, platform_get_irq() for the PIO node returns EPROBE_DEFER
# forever, causing pinctrl/DMA/TWI/MMC to never probe and LABEL=BATOCERA to fail.
CONFIG_AW_WAKEUPGEN=y

# intc-nmi@7010320 uses allwinner,sun8i-nmi — AXP8191 PMIC interrupt-parent.
# Without this, AXP8191 fails EPROBE_DEFER at 5 usecs (interrupt domain not found),
# its aldo1 regulator never registers, twi0 twi-supply fails at 0 usecs, sdc0 defers.
CONFIG_AW_SUN8I_NMI=y

# HANG #7 (2026-07-04): serial console never gets a working login shell.
# Root cause: sun60iw2p1.dtsi's uart0 node uses
# `compatible = "allwinner,uart-v100"`. The BSP ships TWO competing UART
# drivers under drivers/uart/: the default one (CONFIG_AW_UART,
# drivers/uart/sunxi-uart.c, function sunxi_uart_init - confirmed via
# initcall_debug that THIS is the one that actually runs) only matches
# `allwinner,sun8i-uart` / `allwinner,sun50i-uart` / `allwinner,sun55i-uart`
# in its of_device_id table - it does NOT match `allwinner,uart-v100` at
# all, so it registers the driver infrastructure but never actually probes
# a device for uart0 (dmesg shows the init call succeeding but zero "probe
# of ..." messages for any uart0 platform device). The result: only the
# earlycon (kept alive the whole time via keep_bootcon) ever prints
# anything on the physical serial pins - no real /dev/ttyAS0 device node
# is ever created, so serial-getty@ttyAS0.service permanently fails with
# "Dependency failed" (its dev-ttyAS0.device unit times out waiting for a
# device that udev never creates) - meaning the serial console has NEVER
# had a working interactive login shell in this project, only kernel-log
# output, despite looking like it "worked" the whole time.
#
# The correct driver is the OTHER one: CONFIG_AW_UART_NG
# (drivers/uart/sunxi-uart-ng-core.c), whose of_device_id table explicitly
# includes `allwinner,uart-v100` (confirmed via GitHub code search across
# the BSP repo's sun60iw2/sun65iw1/sun55iw6 dtsi files, which all use this
# same compatible string with this same "NG" driver). Confirmed its
# registered tty device name is "ttyAS" (drivers/uart/sunxi-uart-ng-core.c:
# `.dev_name = "ttyAS"` when CONFIG_SERIAL_8250 is set, which it is here) -
# i.e. `console=ttyAS0,115200` (already in cubie-a7s.nix's kernelParams,
# taken from OctaneOS's reference extlinux.conf) was always the CORRECT
# console name, it just needed the matching driver enabled to ever
# actually create that device.
#
# AW_UART and AW_UART_NG both define a same-named global
# `sunxi_uart_driver` struct (and similar internal symbol names) - building
# both `=y` into a non-modular kernel risks a duplicate-symbol link error,
# so AW_UART is explicitly disabled here rather than left at its "default
# y" value.
CONFIG_AW_UART=n
CONFIG_AW_UART_NG=y
CONFIG_AW_SERIAL_CONSOLE=y

# BSP platform — required for ALL BSP drivers (CCU, MMC, display, USB)
# Chain: AW_BSP → AW_CCU → AW_SUN60IW2_CCU (auto via ARCH_SUN60IW2 default)
CONFIG_AW_BSP=y
CONFIG_AW_KERNEL_ORIGIN=y
CONFIG_ARCH_SUN60I=y
CONFIG_ARCH_SUN60IW2=y
CONFIG_AW_IC_BOARD=y
CONFIG_AW_SOC_NAME="A733"

# disable mainline sunxi-ng CCU — BSP CCU replaces it (duplicate symbols)
CONFIG_SUNXI_CCU=n

# mainline sunxi-mmc conflicts with BSP AW_MMC — both register as 'sunxi-mmc'
CONFIG_MMC_SUNXI=n

# BSP input sensor init references irq_to_desc which is not exported
CONFIG_AW_INPUT_SENSORINIT=n

# BSP MMC driver — matches allwinner,sunxi-mmc-v5p3x in the A733 DTS
CONFIG_AW_MMC_HSQ=y
CONFIG_AW_MMC=y
CONFIG_AW_MMC_V5P3X=y

# Onboard Gigabit Ethernet — BSP STMMAC driver for allwinner,sunxi-gmac-210
CONFIG_AW_STMMAC_ETH=y

# MediaTek MT7921K PCIe WiFi (M.2 2230 dock streaming radio)
CONFIG_MT7921E=y

# USB-A host controller — Allwinner BSP EHCI/OHCI for the physical USB-A port
CONFIG_USB_SUNXI_HCD=y
CONFIG_USB_SUNXI_HCI=y
CONFIG_USB_EHCI_HCD_SUNXI=y
CONFIG_USB_SUNXI_EHCI1=y
CONFIG_USB_OHCI_HCD_SUNXI=y
CONFIG_USB_SUNXI_OHCI1=y

# USB HID — required for USB gamepads, keyboards, and mice
CONFIG_USB_HID=y
CONFIG_HID_GENERIC=y

# Joystick/gamepad input — required for controllers in EmulationStation
# JOYSTICK_XPAD: handles 8BitDo and other gamepads in X-input (Xbox) mode
# JOYSTICK_HIDRAW: raw HID fallback for gamepads not handled by specific drivers
# XPAD_FF disabled: not needed for bringup, reduces irq_out traffic.
# XPAD_LEDS enabled: sends the LED ring assignment (player 1 indicator) via
# interrupt OUT. Without it the 8BitDo resets after ~90s (no player claim received).
# The EP0 vendor magic message is the actual EHCI TT killer — that is skipped via
# skip_magic_message=true in xpad.c, not here.
CONFIG_INPUT_JOYSTICK=y
CONFIG_JOYSTICK_XPAD=y
CONFIG_JOYSTICK_XPAD_FF=n
CONFIG_JOYSTICK_XPAD_LEDS=y
CONFIG_JOYSTICK_HIDRAW=y

# required for evmapy
CONFIG_INPUT_UINPUT=y

# required for squashfs + overlayfs + tmpfs (initramfs overlay mount)
CONFIG_NLS_ISO8859_1=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_OVERLAY_FS=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_ZSTD=y

# required for AIC8800 USB WiFi
CONFIG_USB_NET_DRIVERS=y
CONFIG_USB_USBNET=y

# disable Broadcom SDIO WiFi — not present (uses AIC8800 USB); bcmdhd references
# sunxi_wlan_* symbols not built, causing modpost errors
CONFIG_BCMDHD=n

# mainline MFD AXP20X conflicts with BSP AW_MFD_AXP2101 — duplicate axp20x_* symbols
CONFIG_MFD_AXP20X=n
CONFIG_MFD_AXP20X_I2C=n
CONFIG_MFD_AXP20X_RSB=n

# AXP8191 PMIC driver chain
# AW_DMA: BSP DMA driver — required by AW_TWI (Kconfig dependency)
# AW_TWI: BSP I2C driver matching allwinner,sunxi-twi-v101
# AW_MFD_AXP2101_I2C: MFD driver that recognizes x-powers,axp8191
# AW_REGULATOR_AXP2101: exposes regulators to the regulator framework
CONFIG_AW_DMA=y
CONFIG_AW_TWI=y
CONFIG_AW_MFD_AXP2101_I2C=y
CONFIG_AW_REGULATOR_AXP2101=y

# =============================================================================
# BSP DRM/KMS display stack — INTENTIONALLY DISABLED for this headless-only build.
#
# History (see linux-cubie-a7s.nix patches list / project plan doc for full detail):
# this board has no HDMI (USB-C DisplayPort Alt Mode only) and this is a
# boot+serial+ethernet+SSH-only headless target, so no display output is ever
# needed. Enabling the BSP DRM stack (as OctaneOS/Radxa do for their
# display-attached reference hardware) surfaced THREE separate vendor-driver
# bugs during bring-up on real hardware with no display connected:
#   1. sunxi-hdmi hotplug-detect kthread logs "drm hdmi detect: disconnect"
#      every ~20ms at KERN_INFO — floods/freezes the 115200-baud serial
#      console (worked around separately via boot.consoleLogLevel=4 in
#      configuration.nix, but this alone does not fix #2/#3 below).
#   2. sunxi_drm_bind() in bsp/drivers/drm/sunxi_drm_drv.c unconditionally
#      calls commit_init_connecting(drm) even when no connector is detected
#      (private->priv->connecting_head list stays empty). That function's
#      early NULL-list checks correctly print an error and return, but their
#      return values are never checked by the caller, so execution falls
#      through into an empty atomic-commit loop and hangs forever in
#      drm_atomic_commit() on a completely untouched state. Patch 1013
#      (patches/1013-sunxi-drm-skip-commit-init-connecting-when-headless.patch)
#      fixes this specific bug with a list_empty() guard — CONFIRMED on real
#      hardware to eliminate this exact hang (the two error lines disappear).
#   3. Even with #2 fixed, a SECOND, earlier, still-unresolved hang occurs:
#      a periodic (~1.1s cadence, 5 repetitions) eDP AUX-channel timeout burst
#      ("[EDP_ERR]: edp wait aux reply timeout!", trilinear_aux_read retry
#      exhausted) that eventually stops producing ANY further kernel output,
#      reproduced identically twice. This happens BEFORE
#      setup_bootloader_connecting_state() is reached (patch 1013's guard
#      can't help), most likely inside component_bind_all()'s eDP sub-driver
#      probe/.bind() callback in the Cadence combo-PHY/eDP stack, which
#      appears to retry AUX/EDID reads with no overall give-up path.
#
# Rather than continue hand-patching individual vendor DRM bugs one at a
# time (this would be the 3rd such patch), the whole BSP DRM/eDP/HDMI/
# combo-PHY chain is disabled here at the Kconfig level. This is safe: no
# other subsystem in this board's config depends on DRM. Patch 1013 is left
# in place in linux-cubie-a7s.nix's patches list (harmless no-op once
# sunxi_drm_drv.c is excluded from the build by these Kconfig settings) in
# case a future person/agent re-enables DRM for the Phase 6 DP-Alt-Mode
# stretch goal — if you do that, you will very likely need to debug and fix
# hang #3 above as well before display output actually works end-to-end.
#
# NOTE: CONFIG_AW_TYPEC_HUSB311/TYPEC_TCPM/TYPEC_TCPCI/USB_SUNXI_DWC3/etc.
# further below are DELIBERATELY KEPT ENABLED — those drive general USB-C
# port function (USB-PD negotiation, DWC3 host/OTG role) and are unrelated
# to display output; disabling them would break plain USB-C port usage.
#
# HANG #4 (found after first no-DRM boot test, FIXED below): disabling
# CONFIG_AW_CADENCE_COMBOPHY entirely (originally done above alongside the
# DRM chain, on the assumption it was *only* a display/DP-altmode PHY)
# turned out to be a mistake — this combo-PHY block is *also* the SoC's
# only USB3.0 SuperSpeed PHY provider (its own Kconfig help text literally
# says "PCIe/USB3.0/DisplayPort combo PHY" and its source
# drivers/phy/sunxi-cadence-combophy.c has zero dependency on
# CONFIG_AW_DRM/CONFIG_DRM — it only pulls in GENERIC_PHY + EXTCON). With it
# disabled, the mainline DWC3 core driver bound to usbc2's
# "allwinner,sunxi-plat-dwc3" node could never obtain its usb3_generic_phy
# and got stuck in permanent -EPROBE_DEFER, which cascaded up:
#   dwc3-sunxi-plat.c: "failed to get drvdata dwc3" (child dwc3 core never
#     finished probing) -> tcpci_husb311: "failed to find usb power" ->
#     "fail to register tcpci port, -517" (-EPROBE_DEFER), retried at
#     growing backoff intervals forever with the whole kernel boot process
#     appearing to hang (confirmed via network: board never appeared on
#     LAN, never responded to Enter on serial console, across 2 separate
#     SD cards — ruling out a card-hardware issue).
# FIX: re-enable CONFIG_AW_CADENCE_COMBOPHY=y (needed purely for the shared
# USB3/PCIe/DP PHY hardware block, NOT for display) and
# CONFIG_TYPEC_MUX_SUNXI_PHY_SWITCHER=y (drivers/usb/typec/mux/
# sunxi-phy-switcher.c — a generic TypeC orientation/mux driver, also zero
# dependency on DRM, that fetches "dp-phy"/"usb-phy" phandles FROM the
# combo-PHY above; the board's DTS wires HUSB311's TCPM mux through this
# switcher regardless of whether DP-altmode is actually used, so it likely
# needs to probe successfully too for the TypeC/USB stack to settle).
# CONFIG_TYPEC_DP_ALTMODE stays =n (this is the actual DP-altmode *protocol*
# support built on top of the mux/phy — safe to leave off since we have no
# display and it was never implicated in any hang; keeping it off also
# means the previously-hanging eDP/DRM code paths remain fully unreachable).
#
# HANG #5 (found after the combophy-fix boot test, FIXED below): the hang #4
# EPROBE_DEFER loop persisted IDENTICALLY even with the combo-PHY + phy
# switcher re-enabled. Verified via the built kernel's /build/.config that
# COMBOPHY/PHY_SWITCHER/HUSB311/USB_DWC3 were all =y — so the missing piece
# was something else. Root cause: CONFIG_AW_PCK600_DOMAINS (previously =n
# below, also swept into the DRM-disable batch under the assumption it was
# display-related) gates the PCK-600 *power-domain controller* driver for
# the "allwinner,sun60iw2-pck-600" power-controller node (pck-600@7060000
# in sun60iw2p1.dtsi). The DWC3 core node for usbc2 (xhci2-controller@6a00000,
# compatible "snps,dwc3") carries `power-domains = <&pd SUN60IW2_PCK_USB2>;`
# — with the genpd provider driver compiled out, the kernel's power-domain
# framework defers the DWC3 core's probe FOREVER waiting for a provider that
# can never appear. So DWC3 never set its drvdata -> dwc3-sunxi-plat glue
# "failed to get drvdata dwc3" -> husb311 tcpci -517 retry loop -> hang.
# FIX: CONFIG_AW_PCK600_DOMAINS=y. This is a power-domain controller driver
# (used by USB2/PCIE/NPU/VE/VI/DE/GPU domains), NOT a DRM driver. The
# display-related domains it also serves (DE_SYS/VO0/VO1/...) are harmless
# to expose: their consumer drivers are compiled out (CONFIG_AW_DRM=n), so
# nothing references those domains and nothing can defer on them.
# =============================================================================
CONFIG_DRM=n
CONFIG_AW_PCK600_DOMAINS=y

# PCIe RC (host) mode for the on-board M.2 slot (pcie_rc node in the DTS,
# compatible "allwinner,sunxi-pcie-v300-rc"). bsp/drivers/pcie/Kconfig
# defines a `choice` (AW_PCIE_RC / AW_PCIE_EP / AW_PCIE_NONE) that DEFAULTS
# TO AW_PCIE_NONE if left unset — neither this fragment nor the base
# defconfig ever set it, so `make olddefconfig` was silently compiling the
# PCIe host driver out entirely, even though the DT node is enabled
# (status=okay) and CONFIG_PCI/CONFIG_PCIEPORTBUS/CONFIG_PCI_HOST_GENERIC
# only bring up the generic PCI core, not this SoC-specific controller.
# Symptom without this: /sys/bus/pci/devices/ stays empty and dmesg shows
# zero "sunxi:pcie-rc-*" probe messages even with a device plugged in.
# The PHY (CADENCE_COMBOPHY, below) and power-domain (PCK600_DOMAINS,
# above) dependencies were already enabled incidentally while fixing an
# unrelated USB3/DWC3 hang, so this is the only missing piece.
CONFIG_AW_PCIE_RC=y

# Allwinner thermal sensor driver (bsp/drivers/thermal/sunxi_thermal.c,
# module "sunxi-thermal"). bsp/drivers/thermal/Kconfig declares AW_THERMAL
# as a plain tristate with no `default` line, so it resolves to n unless
# set explicitly — neither this fragment nor the base defconfig ever set
# it. Confirmed exact match: the upstream sun60iw2p1.dtsi thermal-sensor
# node is `ths@2522000 { compatible = "allwinner,sun60iw2p1-ths"; ... }`,
# and sunxi_thermal.c's of_device_id table has an exact matching entry
# `{ .compatible = "allwinner,sun60iw2p1-ths", .data = &sun60iw2p1_ths }`.
# The already-enabled CONFIG_SUN8I_THERMAL=y (mainline drivers/thermal/
# sun8i_thermal.c) is a completely different driver targeting older
# H3/H5/H6/A64/A83T Allwinner SoCs and will never bind to this node —
# it's harmless dead weight, not a substitute. Without AW_THERMAL, the
# fully-wired DT thermal zones (cpul/cpub/gpu/npu/ddr/skin) have no
# backing sensor driver, so no temps show up anywhere (e.g. in btop).
# Deps: HAS_IOMEM (always true), OF (mandatory on this DT/ARM64 platform),
# NVMEM (already satisfied — CONFIG_NVMEM_SUNXI_SID=y in the base
# defconfig could not be set unless NVMEM was already y, since mainline
# NVMEM provider drivers are nested inside an `if NVMEM ... endif` block).
CONFIG_AW_THERMAL=y

CONFIG_AW_DRM=n
CONFIG_AW_DRM_DE=n
CONFIG_AW_DRM_TCON=n
CONFIG_AW_DRM_TCON_TV=n
CONFIG_AW_DRM_TCON_TOP=n
CONFIG_AW_DRM_EDP=n
CONFIG_AW_DRM_TRILINEAR_EDP14=n
CONFIG_AW_CADENCE_COMBOPHY=y
CONFIG_TYPEC_MUX_SUNXI_PHY_SWITCHER=y
CONFIG_TYPEC_DP_ALTMODE=n

# HUSB311 TypeC controller — KEPT ENABLED for USB-C USB-PD/data-role
# negotiation (needed for the USB-C port to work as a plain USB port at
# all, per patch 1004). This does NOT re-enable display output — DP
# Alt Mode itself is disabled above via TYPEC_DP_ALTMODE=n and the combo-PHY
# DRM chain, so HUSB311 will simply never attempt a DP mux switch.
CONFIG_AW_TYPEC_HUSB311=y
# TYPEC core must be =y (not =m) — TCPCI/TCPM can't link built-in into a module framework
CONFIG_TYPEC=y

# USB_SUNXI_DWC3: BSP gate for the Allwinner USB3 DWC3 glue stack
# usbc2@12 uses compatible "allwinner,sunxi-plat-dwc3" (DWC3_SUNXI_PLAT)
# HUSB311 defers forever if the DWC3 role-switch endpoint it references never probes
CONFIG_USB_SUNXI_DWC3=y
CONFIG_DWC3_SUNXI_PLAT=y
CONFIG_PHY_SUNXI_PLAT=y

# DWC3 OTG + USB role switching — required for USB-C DP Alt Mode
# Without USB_DWC3_DUAL_ROLE, the DWC3 core (core.c dwc3_core_init_mode) prints
# "Configuration mismatch. dr_mode forced to host" even when DTS has dr_mode="otg".
# The role-switch endpoint (dwc3_0_role_switch) is never registered → HUSB311 gets
# EPROBE_DEFER forever from usb_role_switch_get() → combophy never switches to DP.
#
# USB_DWC3_DUAL_ROLE has "depends on USB_GADGET" in Kconfig — without USB_GADGET=y,
# olddefconfig silently falls back to USB_DWC3_HOST=y even if DUAL_ROLE=y is in the
# fragment.  USB_GADGET enables the Linux USB device/gadget framework (zero overhead
# when no gadget function is configured).
CONFIG_USB_GADGET=y
CONFIG_USB_DWC3_DUAL_ROLE=y
CONFIG_USB_ROLE_SWITCH=y

# g_ether legacy gadget driver — provides usb0 CDC-ECM/RNDIS networking over
# the USB-C port for first-boot SSH access (mirrors radrubble/Zero3's
# `boot.kernelModules=["g_ether"]` setup). Builds on USB_GADGET+
# USB_DWC3_DUAL_ROLE above, which already give us a UDC (DWC3 in device
# mode).
CONFIG_USB_ETH=m
CONFIG_USB_LIBCOMPOSITE=m
# TCPM/TCPCI must be =y (not =m) — AW_TYPEC_HUSB311 is built-in and depends on them
CONFIG_TYPEC_TCPM=y
CONFIG_TYPEC_TCPCI=y

# =============================================================================
# Disable BSP drivers not needed for OctaneOS bringup
#
# AW_VIDEO_ENCODER_DECODER: cedar-ve hardware video codec — default y in Kconfig
# but cedar_ve.h is generated by the Allwinner SDK and not in the BSP git tree.
# Hardware video decode is not required for EmulationStation/RetroArch bringup.
# AW_VIDEO_GOOGLE_DECODER: google VP9/AV1 decoder — same situation, not needed.
# =============================================================================
CONFIG_AW_VIDEO_ENCODER_DECODER=n
CONFIG_AW_VIDEO_GOOGLE_DECODER=n

# =============================================================================
# GPU — Imagination PowerVR BXM-4-64 MC1
# pvrsrvkm.ko is built automatically when bsp/ is present (bsp/modules/gpu/).
# Disable conflicting DRM drivers from the base defconfig.
# DEVFREQ_GOV_SIMPLE_ONDEMAND: required for GPU DVFS support in pvrsrvkm.
# =============================================================================

# Disable mainline DRM drivers that conflict with BSP GPU (base defconfig enables these)
CONFIG_DRM_PANFROST=n
CONFIG_DRM_LIMA=n
# Disable upstream open PowerVR driver if present — we use the BSP pvrsrvkm instead
CONFIG_DRM_IMAGINATION=n

# GPU DVFS governor — pvrsrvkm checks for this at init
CONFIG_DEVFREQ_GOV_SIMPLE_ONDEMAND=y
